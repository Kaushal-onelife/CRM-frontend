# Copy to .env and fill in real values.
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the client bundle.

# Backend API base URL.
# - Local web / iOS simulator: http://localhost:5000/api
# - Android emulator:           http://10.0.2.2:5000/api
# - Physical device:            http://<your-LAN-ip>:5000/api
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Supabase. Leave both empty to keep the app in mock mode.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
